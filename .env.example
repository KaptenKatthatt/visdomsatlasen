# Node-serverns port (containern lyssnar på 8080; mappas till host-port 3001 i
# deploy.yml, nås via Tailscale på http://<tailscale-ip>:3001).
PORT=8080
# Bind-adress. Utelämna för alla gränssnitt (0.0.0.0) — krävs i Docker. Sätt
# bara om du vill binda ett specifikt nät.
# HOST=0.0.0.0
# SQLite-databasen som ingest fyller. Ligger i en volym på VPS:en.
DATABASE_URL=./data/visdomsatlasen.db
# Katalogen med det byggda SPA:t som servern levererar.
STATIC_DIR=./dist

# Appen körs Tailscale-only (som newsAgg) och kräver ingen inloggning för att
# läsa — allt innehåll är public domain och ingen personlig data ligger på
# servern. Bara den skrivande endpointen POST /api/ingest skyddas av en
# bearer-token; utelämna för att falla tillbaka på newsAggs UPDATE_TOKEN.
INGEST_TOKEN=byt-mig

# Testarläget: sätt en lång slumpad kod (≥24 tecken) för att gömma HELA appen
# (SPA + /api) bakom en kod-sida — tänkt när servern exponeras publikt via
# Tailscale Funnel för inbjudna testare. Utelämnad ⇒ spärren av (appen öppen
# inom tailnet, som förr). "Stäng av alla" = byt koden och starta om.
# ACCESS_CODE=byt-till-en-lang-slumpad-kod

# Ollama via Hermes-gateway (samma abonnemang som newsAgg). Används för att
# översätta de icke-svenska traditionerna (stoicism, buddhism, taoism).
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=gemma4:31b-cloud

# Auto-ingest: vid serverstart fylls verk som saknas i databasen på i bakgrunden
# (så ett nytt verk kommer in automatiskt vid nästa deploy). Sätt "off" för att
# bara ingesta manuellt via `npm run ingest`.
# AUTO_INGEST=off
# TRANSLATE=off  # hoppa över Ollama-översättningen (lagra källspråket)

# Bibelkälla: utelämna för getbible (hela 1917 års bibel). Sätt till "fixture"
# för att köra mot det lokala urvalet i data/fixtures/ (verifiering utan nät).
# BIBLE_SOURCE=fixture
# GETBIBLE_BASE=https://api.getbible.net/v2
