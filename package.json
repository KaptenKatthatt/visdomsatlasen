{
  "name": "visdomsatlasen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check:types": "tsc -b",
    "check:coverage": "type-coverage -p tsconfig.app.json --at-least 100",
    "check:length": "fallow health --complexity",
    "check:dead": "fallow dead-code",
    "check": "npm run check:types && npm run check:coverage && npm run check:length && npm run check:dead"
  },
  "dependencies": {
    "@fontsource/eb-garamond": "^5.2.7",
    "@tanstack/react-router": "^1.132.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "fallow": "^3.2.0",
    "type-coverage": "^2.29.7",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.1"
  }
}
