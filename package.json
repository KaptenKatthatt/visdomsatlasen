    "@hono/node-server": "^1.19.14",
    "@tanstack/react-router": "^1.132.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
