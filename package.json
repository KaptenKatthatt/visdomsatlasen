{
  "name": "visdomsatlasen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/index.ts",
    "server": "tsx server/index.ts",
    "ingest": "tsx scripts/ingest.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check:types": "tsc -b",
    "check:lint": "eslint .",
    "check:content": "tsx scripts/validera-innehall.ts",
    "check:coverage": "type-coverage -p tsconfig.app.json --at-least 100 && type-coverage -p tsconfig.server.json --at-least 100",
    "check:length": "fallow health --complexity",
    "check:dead": "fallow dead-code",
    "check": "npm run check:types && npm run check:lint && npm run test && npm run check:content && npm run check:coverage && npm run check:length && npm run check:dead"
  },
  "dependencies": {
