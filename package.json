    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fallow": "^3.2.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "type-coverage": "^2.29.7",
    "typescript": "~5.8.3",
